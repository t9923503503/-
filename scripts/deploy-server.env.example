# Copy this file to scripts/deploy-server.env on the server and edit values.
# The real env file is gitignored.

# Git checkout on the server
APP_DIR=/var/www/ipt
WEB_DIR=/var/www/ipt/web
REMOTE_NAME=origin
APP_BRANCH=main

# Build/install steps
ROOT_INSTALL_ENABLED=1
ROOT_BUILD_ENABLED=1
WEB_INSTALL_ENABLED=1
WEB_BUILD_ENABLED=1
ROOT_INSTALL_COMMAND=npm ci
ROOT_BUILD_COMMAND=npm run build
WEB_INSTALL_COMMAND=npm ci
WEB_BUILD_COMMAND=npm run build

# Static deploy
# If nginx serves a dedicated directory, prefer:
#   STATIC_TARGET_DIR=/var/www/ipt-dist
#   STATIC_SYNC_MODE=mirror
#
# Current lpvolley.ru layout serves SPA files from the git checkout itself,
# but the deploy script builds from a clean git export and overlays only the
# resulting artifacts into APP_DIR.
STATIC_BUILD_DIR=/var/www/ipt/dist
STATIC_TARGET_DIR=/var/www/ipt
STATIC_SYNC_MODE=overlay
ALLOW_SYNC_TO_APP_DIR=1

# Backup storage
BACKUP_ENABLED=1
BACKUP_DIR=/var/www/ipt/.deploy-backup

# Next.js runtime
SERVICE_NAME=kotc-web.service

# Health checks
HEALTHCHECK_ENABLED=1
HEALTHCHECK_TIMEOUT_SEC=15
# Seconds to wait after systemctl restart before probing Next (avoids curl race on 127.0.0.1)
POST_RESTART_HEALTHCHECK_DELAY_SEC=2
NEXT_HEALTHCHECK_URL=http://127.0.0.1:3101/
NEXT_HEALTHCHECK_CODES=200,302,401
PUBLIC_HEALTHCHECK_URL=https://lpvolley.ru/calendar
PUBLIC_HEALTHCHECK_CODES=200
NEXT_ASSET_HEALTHCHECK_URLS=https://lpvolley.ru/admin/login,https://lpvolley.ru/profile
# Optional body-level check for mojibake/stale Next bundles on a known public page.
# Pick a stable public URL with Cyrillic UI text rendered by the target route.
# PUBLIC_BODY_HEALTHCHECK_URL=https://lpvolley.ru/calendar/aa8a1292-deb9-4345-8e4d-4d72ed6261a1
# PUBLIC_BODY_HEALTHCHECK_CONTAINS=Подать заявку
# PUBLIC_BODY_HEALTHCHECK_NOT_CONTAINS=РџРѕРґР°С‚СЊ

# Проверка: /kotc/assets/app.css должен быть text/css, не text/html (nginx SPA-fallback)
KOTC_CSS_HEALTHCHECK_URL=https://lpvolley.ru/kotc/assets/app.css

# Optional DB step
RUN_MIGRATIONS=0
# Example:
# MIGRATE_COMMAND=psql "$DATABASE_URL" -v ON_ERROR_STOP=1 -f migrations/021_thai_judge_v2.sql
