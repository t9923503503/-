# Preferred: own server PostgREST config.
# Example:
# APP_API_BASE=https://lpvolley.ru/api
# POSTGREST_JWT_SECRET=change-me
# Optional fallback if you only have an anon key:
# APP_SUPABASE_ANON_KEY=change-me
APP_API_BASE=
POSTGREST_JWT_SECRET=
APP_SUPABASE_ANON_KEY=

# Legacy fallback: direct PostgreSQL connection.
# Keep empty when the app should work only through your own server API.
DATABASE_URL=

# Optional: if set, SPA must send matching header X-Org-Secret for GET/POST /api/tournaments/:id
# (see shared/api.js _getAuthHeader / kotc3_org_secret).
TOURNAMENT_SYNC_SECRET=

# Судьи: /sudyam, /court (список турниров). Отдельно от админки.
# Приоритет: JUDGE_PIN, иначе SUDYAM_PIN (старое имя). В dev без env — 2525.
JUDGE_PIN=
# SUDYAM_PIN=

# Админ /admin/* — только ADMIN_PIN / ADMIN_CREDENTIALS_JSON (см. docs). Не совмещать с JUDGE_PIN.
# ADMIN_PIN=
# ADMIN_SESSION_SECRET=
